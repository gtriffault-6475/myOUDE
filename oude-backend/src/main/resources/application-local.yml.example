# Copier ce fichier en application-local.yml (gitignored) pour le dev local
# Ce fichier est un template — ne pas mettre de vrais secrets ici
spring:
  datasource:
    url: jdbc:postgresql://${DB_HOST:localhost}/${DB_NAME:oude_db}
    username: ${DB_USER:oude_dev}
    password: ${DB_PASSWORD:dev_only}
  jpa:
    show-sql: false
  security:
    oauth2:
      resourceserver:
        jwt:
          # Mock SSO local — WireMock ou mock embarqué
          jwks-uri: http://localhost:9090/jwks
          issuer-uri: http://localhost:9090

# Identité mock du vendeur (configurable pour tester différents portefeuilles)
oude:
  mock:
    vendeur-id: "VEND-001"
    prenom: "Natasha"
    email: "natasha.martin@renault.com"
    portefeuille-id: "PF-BOULOGNE-001"

# APIs Renault — en local, les stubs sont utilisés automatiquement (valeur "stub")
renault:
  api:
    leads-url: stub      # TODO: AQ-2 — remplacer par l'URL Apigee X réelle
    affaires-url: stub   # TODO: AQ-3 — remplacer par l'URL Apigee X réelle

logging:
  level:
    com.renault.oude: DEBUG
    org.springframework.security: DEBUG
